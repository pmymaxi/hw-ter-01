# Включаем локальный кэш для пройвадеров, чтобы каждый раз не скачивать, директория с кэш должна быть уже создана
plugin_cache_dir = "$HOME/.terraform.d/plugin-cache"

provider_installation {
    #Включаем поиск пройвайдеров из локального кэша
    filesystem_mirror {
        path    = "$HOME/.terraform.d/plugin-cache"
    }
    # Если нет в локальном хранилище то скачивам с зеркала yandex
    network_mirror {
        url = "https://terraform-mirror.yandexcloud.net/"
        include = ["registry.terraform.io/*/*"]
    }
    # Исключаем возможность поиска в registry.terraform
    direct {
    exclude = ["registry.terraform.io/*/*"]
  }
}

